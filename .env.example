# NetflowSight Configuration

# Threat Intelligence APIs
ABUSEIPDB_API_KEY=your_abuseipdb_key_here
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# AI Configuration (Optional - for AI-powered reporting)
OPENAI_API_KEY=your_openai_key_here
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=4000

# Analysis Settings
SAFE_DOMAINS_FILE=data/safe_domains.txt
THREAT_CACHE_ENABLED=true
THREAT_CACHE_TTL_HOURS=24

# Performance
NFSTREAM_N_METERS=0  # 0 = auto-detect based on CPU cores
STATISTICAL_ANALYSIS=true
N_DISSECTIONS=20
DECODE_TUNNELS=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/netflowsight.log
