# NetflowSight 数据源配置文件
# 将此文件保存为 data/sources/sources.yaml 或 sources.json

{
  "version": "1.0",
  "description": "NetflowSight 数据源配置示例",
  "sources": [
    {
      "name": "alexa_top_domains",
      "category": "whitelist_domains",
      "source_type": "remote_url",
      "url_or_path": "https://s3.amazonaws.com/alexa-static/top-1m.csv.zip",
      "update_interval_hours": 168,
      "enabled": true,
      "format": "csv",
      "description": "Alexa Top 1M 域名白名单（每周更新）"
    },
    {
      "name": "phishtank_urls",
      "category": "threat_urls",
      "source_type": "remote_url",
      "url_or_path": "https://data.phishtank.com/data/online-valid.csv.gz",
      "update_interval_hours": 24,
      "enabled": true,
      "format": "csv",
      "description": "PhishTank 钓鱼 URL 列表（需要注册 API Key）"
    },
    {
      "name": "urlhaus_malicious",
      "category": "threat_urls",
      "source_type": "remote_url",
      "url_or_path": "https://urlhaus.abuse.ch/downloads/csv_recent/",
      "update_interval_hours": 1,
      "enabled": true,
      "format": "csv",
      "description": "URLhaus 恶意 URL 列表（每小时更新）"
    },
    {
      "name": "spamhaus_drop",
      "category": "threat_ips",
      "source_type": "remote_url",
      "url_or_path": "https://www.spamhaus.org/drop/drop.txt",
      "update_interval_hours": 24,
      "enabled": true,
      "format": "text",
      "description": "Spamhaus DROP 列表（恶意 IP 段）"
    },
    {
      "name": "custom_whitelist_domains",
      "category": "whitelist_domains",
      "source_type": "local_file",
      "url_or_path": "data/sources/custom_whitelist.txt",
      "update_interval_hours": 0,
      "enabled": true,
      "format": "text",
      "description": "企业自定义白名单域名（手动维护）"
    },
    {
      "name": "custom_threat_ips",
      "category": "threat_ips",
      "source_type": "local_file",
      "url_or_path": "data/sources/custom_threat_ips.txt",
      "update_interval_hours": 0,
      "enabled": true,
      "format": "text",
      "description": "企业自定义威胁 IP 列表（手动维护）"
    }
  ]
}
